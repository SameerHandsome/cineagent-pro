# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.Python
*.egg
*.egg-info/
dist/
build/
*.whl

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Environment variables — NEVER commit these ────────────────────────────────
.env
.env.local
.env.*.local

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# ── Docker ───────────────────────────────────────────────────────────────────
*.log

# ── Node (for Playwright / Filesystem MCP) ───────────────────────────────────
node_modules/
.npm/

# ── Uploads (user files — not versioned) ─────────────────────────────────────
uploads/*
!uploads/.gitkeep

# ── Celery ───────────────────────────────────────────────────────────────────
celerybeat-schedule
celerybeat.pid
